<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" Name="GrubStation" Language="1033" Version="$(var.Version)" Manufacturer="Jeremy Jack" UpgradeCode="2e8b9308-466d-4952-9d33-4f9342718712">
        <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />

        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <UIRef Id="WixUI_Minimal" />
        <!-- WixUI_Minimal requires an RTF formatted EULA. Point this to a local RTF file -->
        <WixVariable Id="WixUILicenseRtf" Value=".build/windows/eula.rtf" />

        <!-- Add/Remove Programs Properties -->
        <Property Id="ARPCOMMENTS" Value="Agent to manage bare-metal OS booting via Home Assistant and WOL" />
        <Property Id="ARPCONTACT" Value="Jeremy Jack" />
        <Property Id="ARPHELPLINK" Value="https://github.com/jjack/grubstation" />
        <Property Id="ARPURLINFOABOUT" Value="https://github.com/jjack/grubstation" />

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFilesFolder">
                <Directory Id="INSTALLDIR" Name="GrubStation" />
            </Directory>
            <Directory Id="ProgramMenuFolder">
                <Directory Id="ApplicationProgramsFolder" Name="GrubStation"/>
            </Directory>
        </Directory>

        <DirectoryRef Id="ApplicationProgramsFolder">
            <Component Id="ApplicationShortcut" Guid="*">
                <Shortcut Id="ApplicationStartMenuShortcut" 
                          Name="GrubStation Setup" 
                          Description="Configure GrubStation"
                          Target="[INSTALLDIR]grubstation.exe"
                          Arguments="setup"
                          WorkingDirectory="INSTALLDIR" />
                <RemoveFolder Id="CleanUpShortCut" On="uninstall"/>
                <RegistryValue Root="HKCU" Key="Software\JeremyJack\GrubStation" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
            </Component>
        </DirectoryRef>

        <ComponentGroup Id="ProductComponents" Directory="INSTALLDIR">
            <Component Id="Executable" Guid="*">
                <File Id="GrubStationEXE" Name="grubstation.exe" Source="$(var.BinaryPath)" KeyPath="yes" />
            </Component>
        </ComponentGroup>

        <!-- CUSTOM ACTION: Launch the TUI -->
        <CustomAction Id="LaunchConfig" 
                      FileKey="GrubStationEXE" 
                      ExeCommand="setup" 
                      Return="asyncNoWait" />

        <InstallExecuteSequence>
            <!-- Only run the config wizard on the first install, not on uninstalls -->
            <Custom Action="LaunchConfig" After="InstallFinalize">NOT Installed</Custom>
        </InstallExecuteSequence>

        <Feature Id="ProductFeature" Title="GrubStation" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
            <ComponentRef Id="ApplicationShortcut" />
        </Feature>
    </Product>
</Wix>